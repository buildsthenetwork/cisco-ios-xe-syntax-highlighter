hostname {{ hostname }}

ip domain-name {{ domain_name }}

username {{ username }} privilege 15 secret {{ password_hash }}

ip name-server {{ dns_server_1 }} {{ dns_server_2 }}

ntp server {{ ntp_server }}

logging host {{ syslog_server }}
!-----------------------------------------------------------
{# ====================================== #}
{# Global Configuration                   #}
{# Generated by Ansible                   #}
{# ====================================== #}

hostname {{ hostname }}

{# Configure DNS #}
ip domain-name {{ domain_name }}
!-----------------------------------------------------------
{% for interface in access_ports %}

interface {{ interface.name }}
 description {{ interface.description }}
 switchport
 switchport mode access
 switchport access vlan {{ interface.vlan }}
 spanning-tree portfast
 spanning-tree bpduguard enable

{% endfor %}

!-----------------------------------------------------------


{% for interface in interfaces %}

interface {{ interface.name }}

{% if interface.description %}
 description {{ interface.description }}
{% endif %}

{% if interface.voice_vlan %}
 switchport voice vlan {{ interface.voice_vlan }}
{% endif %}

 switchport access vlan {{ interface.data_vlan }}

{% endfor %}
!-----------------------------------------------------------


{% if enable_dot1x %}

authentication port-control auto
mab
dot1x pae authenticator

{% else %}

authentication open

{% endif %}

!-----------------------------------------------------------
{% for acl in acls %}

ip access-list extended {{ acl.name }}

{% for entry in acl.entries %}
 {{ entry }}
{% endfor %}

{% endfor %}
!-----------------------------------------------------------
hostname {{ device.hostname }}

snmp-server location {{ device.location }}

snmp-server contact {{ device.contact }}
!-----------------------------------------------------------
hostname {{ hostname }}

ip domain-name {{ domain_name | default("example.com") }}

snmp-server location {{ location | default("Unknown") }}
!-----------------------------------------------------------

ip name-server {{ dns_servers | join(" ") }}

{% for interface in interfaces %}

! Interface {{ loop.index }}

interface {{ interface.name }}

{% endfor %}
!-----------------------------------------------------------
{% for vlan in vlans %}

vlan {{ vlan.id }}
 name {{ vlan.name }}

{% endfor %}
!-----------------------------------------------------------
{% for interface in interfaces %}

interface {{ interface.name }}

{% if interface.shutdown %}
 shutdown
{% else %}
 no shutdown
{% endif %}

{% if interface.trunk %}
 switchport mode trunk
 switchport trunk allowed vlan {{ interface.allowed_vlans }}
{% else %}
 switchport mode access
 switchport access vlan {{ interface.access_vlan }}
{% endif %}

{% endfor %}
!-----------------------------------------------------------
{% if aaa_enabled %}

aaa new-model

radius server {{ radius.name }}
 address ipv4 {{ radius.ip }} auth-port 1812 acct-port 1813
 key {{ radius.key }}

aaa group server radius {{ radius.group }}

{% for server in radius.members %}
 server name {{ server }}
{% endfor %}

{% endif %}
!-----------------------------------------------------------
{# Generated by Ansible #}

hostname {{ hostname }}

{% for interface in access_ports %}

interface {{ interface.name }}

{% if interface.description %}
 description {{ interface.description }}
{% endif %}

 switchport
 switchport mode access
 switchport access vlan {{ interface.vlan }}

{% if dot1x %}
 authentication port-control auto
 mab
 dot1x pae authenticator
{% endif %}

 spanning-tree portfast
 spanning-tree bpduguard enable

{% endfor %}

{% if uplinks %}

{% for uplink in uplinks %}

interface {{ uplink.name }}
 description Uplink
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk allowed vlan {{ uplink.allowed_vlans }}

{% endfor %}

{% endif %}
!-----------------------------------------------------------